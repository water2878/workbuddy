# Claw 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 云端服务器配置（用于数据共享）
# ============================================

# 云端合同服务器地址（已配置）
CLOUD_SERVER=http://120.26.84.224:5032

# 云端访问令牌（如果服务器需要认证）
CLOUD_TOKEN=your_token_here

# 销售员ID
SALES_ID=your_sales_id

# ============================================
# 云端图片存储配置（新增）
# ============================================

# 启用云端图片存储（设置为 true 开启）
CLOUD_IMAGES_ENABLED=true

# 云端图片服务器地址（默认使用 CLOUD_SERVER）
# 如果图片存储在不同的服务器，请修改此处
CLOUD_IMAGES_SERVER=http://120.26.84.224:5032

# ============================================
# 本地服务配置
# ============================================

# API 服务地址
API_HOST=127.0.0.1
API_PORT=5032

# WeFlow 配置
WEFLOW_BASE=http://127.0.0.1:5031
WEFLOW_TOKEN=your_weflow_token

# ============================================
# 通知联系人配置
# ============================================

# 合同审批通知联系人（微信昵称）
APPROVAL_CONTACT=张三

# 资料员联系人（产品缺少图片时通知）
MATERIALS_CONTACT=李四
